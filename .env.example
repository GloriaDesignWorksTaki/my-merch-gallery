APP_NAME="My Merch Gallery"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# UI / Laravel の既定ロケール（ja または en）。ブラウザでは右ペインの言語切替でセッション上書き可。
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=my_merch_gallery
DB_USERNAME=yuyataki
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# 公開アップロード（アバター・バンド・マーチ画像）。local=storage/app/public、s3=Cloudflare R2 等
FILESYSTEM_UPLOAD_DRIVER=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# R2 / S3 互換（FILESYSTEM_UPLOAD_DRIVER=s3 のとき必須）
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
# ブラウザから読む公開 URL（R2.dev または Cloudflare で紐付けたカスタムドメイン）
AWS_URL=
# API エンドポイント（例: https://<account_id>.r2.cloudflarestorage.com）
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
